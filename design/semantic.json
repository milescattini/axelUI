{
  "color": {
    "surface": {
      "page":    { "$value": "{color.neutral.50}",  "$type": "color", "$description": "Page background" },
      "raised":  { "$value": "{color.neutral.0}",   "$type": "color", "$description": "Cards, panels — one step above page" },
      "subtle":  { "$value": "{color.neutral.100}", "$type": "color", "$description": "Alternating section tint" },
      "inverse": { "$value": "{color.neutral.900}", "$type": "color", "$description": "Dark hero / CTA sections" }
    },
    "text": {
      "primary":   { "$value": "{color.neutral.900}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.600}", "$type": "color" },
      "tertiary":  { "$value": "{color.neutral.400}", "$type": "color", "$description": "Placeholder, disabled, fine print" },
      "inverse":   { "$value": "{color.neutral.50}",  "$type": "color", "$description": "Text on inverse surfaces" },
      "on-accent": { "$value": "{color.neutral.0}",   "$type": "color", "$description": "Text on accent-coloured backgrounds" }
    },
    "accent": {
      "default": { "$value": "{color.blue.500}", "$type": "color" },
      "hover":   { "$value": "{color.blue.600}", "$type": "color" },
      "subtle":  { "$value": "{color.blue.50}",  "$type": "color", "$description": "Tinted background: tags, highlights, selected state" }
    },
    "border": {
      "default": { "$value": "{color.neutral.200}", "$type": "color" },
      "strong":  { "$value": "{color.neutral.400}", "$type": "color" },
      "focus":   { "$value": "{color.blue.500}",    "$type": "color" }
    }
  },

  "font": {
    "family": {
      "body":    { "$value": "{font.family.display}", "$type": "fontFamily", "$description": "All body and heading text — same family throughout" },
      "heading": { "$value": "{font.family.display}", "$type": "fontFamily" },
      "code":    { "$value": "{font.family.mono}",    "$type": "fontFamily", "$description": "Literal code blocks only — not for labels or decoration" }
    },
    "size": {
      "label":   { "$value": "{font.size.xs}",   "$type": "dimension", "$description": "Eyebrows, captions, metadata" },
      "caption": { "$value": "{font.size.sm}",   "$type": "dimension" },
      "body":    { "$value": "{font.size.base}",  "$type": "dimension" },
      "lead":    { "$value": "{font.size.md}",    "$type": "dimension", "$description": "Intro paragraph / hero subtext" },
      "h3":      { "$value": "{font.size.lg}",    "$type": "dimension" },
      "h2":      { "$value": "{font.size.xl}",    "$type": "dimension" },
      "h1":      { "$value": "{font.size.2xl}",   "$type": "dimension" },
      "display": { "$value": "{font.size.4xl}",   "$type": "dimension", "$description": "Hero headline" }
    },
    "weight": {
      "body":     { "$value": "{font.weight.regular}", "$type": "fontWeight" },
      "emphasis":  { "$value": "{font.weight.medium}",  "$type": "fontWeight" },
      "heading":   { "$value": "{font.weight.strong}",  "$type": "fontWeight" }
    },
    "leading": {
      "heading": { "$value": "{font.leading.tight}", "$type": "number" },
      "body":    { "$value": "{font.leading.base}",  "$type": "number" }
    },
    "tracking": {
      "heading": { "$value": "{font.tracking.tight}",  "$type": "dimension" },
      "label":   { "$value": "{font.tracking.wide}",   "$type": "dimension", "$description": "Uppercase section labels only" },
      "body":    { "$value": "{font.tracking.normal}", "$type": "dimension" }
    }
  },

  "space": {
    "component": {
      "xs": { "$value": "{space.2}", "$type": "dimension", "$description": "Tag / badge internal padding" },
      "sm": { "$value": "{space.3}", "$type": "dimension", "$description": "Button vertical padding, tight list items" },
      "md": { "$value": "{space.4}", "$type": "dimension", "$description": "Button horizontal padding, input padding" },
      "lg": { "$value": "{space.6}", "$type": "dimension", "$description": "Card internal padding" },
      "xl": { "$value": "{space.8}", "$type": "dimension", "$description": "Large card / feature block padding" }
    },
    "layout": {
      "section-y":    { "$value": "{space.24}", "$type": "dimension", "$description": "Vertical padding on full-width sections" },
      "section-y-sm": { "$value": "{space.12}", "$type": "dimension", "$description": "Tighter sections on mobile" },
      "stack":        { "$value": "{space.6}",  "$type": "dimension", "$description": "Default vertical gap between content blocks" },
      "gutter":       { "$value": "{space.6}",  "$type": "dimension", "$description": "Grid column gap" },
      "max-width":    { "$value": "1160px",     "$type": "dimension" }
    }
  },

  "border": {
    "default": { "$value": "{border.width.default} solid {color.neutral.200}", "$type": "border" },
    "card":    { "$value": "{border.width.default} solid {color.neutral.200}", "$type": "border" }
  },

  "radius": {
    "button":  { "$value": "{border.radius.md}", "$type": "dimension" },
    "input":   { "$value": "{border.radius.sm}", "$type": "dimension" },
    "card":    { "$value": "{border.radius.md}", "$type": "dimension" },
    "panel":   { "$value": "{border.radius.lg}", "$type": "dimension" },
    "badge":   { "$value": "{border.radius.pill}", "$type": "dimension" }
  },

  "shadow": {
    "card-hover": { "$value": "{shadow.card}",  "$type": "shadow" },
    "dropdown":   { "$value": "{shadow.float}", "$type": "shadow" }
  },

  "motion": {
    "interactive": { "$value": "{motion.duration.default}", "$type": "duration", "$description": "Hover, focus transitions" },
    "reveal":      { "$value": "{motion.duration.slow}",    "$type": "duration", "$description": "Section or hero animations" },
    "easing":      { "$value": "{motion.easing.standard}",  "$type": "cubicBezier" }
  }
}
